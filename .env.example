POSTGRES_USER=mycalpal
POSTGRES_PASSWORD=mycalpal
POSTGRES_DB=mycalpal
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRE_MINUTES=1440
# Host port the API is exposed on (container still listens on 8000 internally).
# Change this if 8000 is already taken on the host.
API_PORT=8000
# Free key at https://fdc.nal.usda.gov/api-key-signup.html — enables USDA food search with per-portion grams (cup, tbsp, etc.)
USDA_API_KEY=
# FatSecret Platform API (https://platform.fatsecret.com/api/) — broader branded-food coverage and barcode lookup.
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
# Email of the user granted admin access (manage users, reset passwords).
ADMIN_EMAIL=

# --- Auth mode -------------------------------------------------------------
# "local" (default) = built-in email/password + JWT. Works out of the box.
# "sso"             = trust forward-auth headers from an upstream IdP. Only
#                     enable when the API is behind a proxy that strips and
#                     re-sets these headers on every request (e.g. Authentik
#                     + nginx auth_request). Exposing the API directly in SSO
#                     mode lets any client forge identity via headers.
AUTH_MODE=local
# Header names (defaults match Authentik). Change if your IdP uses different ones.
SSO_HEADER_USERNAME=X-authentik-username
SSO_HEADER_EMAIL=X-authentik-email
SSO_HEADER_NAME=X-authentik-name
SSO_HEADER_GROUPS=X-authentik-groups
# Members of this group are granted admin access in SSO mode. Blank = nobody.
SSO_ADMIN_GROUP=
